from flask import Flask, request
from EmotionDetection.emotion_detection import emotion_detector

app = Flask(__name__)

@app.route("/emotionDetector", methods=["GET"])
def emotion_analysis():

    # Get input from request
    text_to_analyze = request.args.get("text")

    # Static analysis friendly check (PEP8 + safe validation)
    if text_to_analyze is None or text_to_analyze.strip() == "":
        return {
            "error": "Blank input provided. Please enter valid text."
        }, 400

    # Call emotion detection function
    result = emotion_detector(text_to_analyze)

    # Defensive programming (static analysis best practice)
    if not result or "error" in result:
        return {
            "error": "Unable to process emotion detection request"
        }, 500

    response = {
        "anger": result.get("anger", 0),
        "disgust": result.get("disgust", 0),
        "fear": result.get("fear", 0),
        "joy": result.get("joy", 0),
        "sadness": result.get("sadness", 0),
        "dominant_emotion": result.get("dominant_emotion", "")
    }

    return response, 200


# Main entry point (clean execution - good for static analysis tools)
if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000, debug=True)
